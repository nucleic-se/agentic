# Provider environment variables for local development.
# This package only uses provider-level settings.

# Anthropic
# AGENTIC_ANTHROPIC_API_KEY=sk-ant-...

# OpenAI-compatible hosts
# AGENTIC_OPENAI_API_KEY=...
# AGENTIC_OPENAI_BASE_URL=https://api.openai.com/v1

# Ollama
# AGENTIC_OLLAMA_API_KEY=...
# AGENTIC_OLLAMA_BASE_URL=http://localhost:11434/v1
